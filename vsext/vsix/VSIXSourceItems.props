<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003" ToolsVersion="14.0">
  <PropertyGroup>
    <DllBinDir>$(SolutionDir)\bin\BinaryVisualizer\$(Configuration)\$(Platform)\</DllBinDir>
    <DllSrcDir>..\dll\</DllSrcDir>
  </PropertyGroup>
  <ItemGroup>
    <VSIXSourceItem Include="$(DllBinDir)BinaryVisualizer.vsdconfig" />
    <VSIXSourceItem Include="$(DllBinDir)BinaryVisualizer.dll">
      <VSIXSubPath>x64</VSIXSubPath>
    </VSIXSourceItem>
    <VSIXSourceItem Include="$(DllSrcDir)BinaryVisualizer.natvis" />
  </ItemGroup>
</Project>